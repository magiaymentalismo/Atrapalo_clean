<body class="main">
    <!-- Splash screen loading -->
    <div id="loading">
        <style>
            body {
                inset: 0;
                overflow: hidden;
                margin: 0;
                padding: 0;
                position: fixed;
            }

            #loading {
                align-items: center;
                display: flex;
                height: 100%;
                justify-content: center;
                width: 100%;
            }

            #loading img {
                animation: 1s ease-in-out 0s infinite alternate breathe;
                opacity: 1;
                width: 350px;
                max-width: 50%;
                margin: 20px;
            }

            @keyframes breathe {
                from {
                    transform: scale(1)
                }

                to {
                    transform: scale(0.95)
                }
            }
        </style>
        <img src="icons/splash-icon.png" alt="Loading indicator" />
    </div>

    <script>
        self.FIREBASE_APPCHECK_DEBUG_TOKEN = location.hostname === 'localhost';
    </script>

    <script src="https://js.stripe.com/v3/"></script>

    <script>
        // add  MetaSEO JS functions here
        function seoNameJS(name, content) {
            safeAttrNameContentSetter(name, content)
        }

        function seoPropertyJS(property, content) {
            safeAttrPropertyContentSetter(property, content)
        }

        function seoAttributeJS(key, val) {
            if (key.indexOf('title') > -1 || key.indexOf('author') > -1) {
                document.title = value
            }
            safeAttrSetter(key, val)
        }

        function safeAttrSetter(attr, value) {
            if (key.indexOf('title') > -1 || key.indexOf('author') > -1) {
                document.title = value
            }
            for (var i = 0; i < document.getElementsByTagName('head')[0].children.length; i++) {
                var element = document.getElementsByTagName('head')[0].children[i]
                if (element.hasAttribute(attr)) {
                    element.setAttribute(attr, value)
                    return
                }
            }
            var ele = document.createElement('meta')
            ele.setAttribute(attr, value)
            document.getElementsByTagName('head')[0].appendChild(ele);
        }

        function safeAttrNameContentSetter(key, value) {
            if (key.indexOf('title') > -1 || key.indexOf('author') > -1) {
                document.title = value
            }
            for (var i = 0; i < document.getElementsByTagName('head')[0].children.length; i++) {
                var element = document.getElementsByTagName('head')[0].children[i]
                if (element.getAttribute('name') == key) {
                    element.setAttribute('content', value)
                    return
                }
            }
            var ele = document.createElement('meta')
            ele.setAttribute('name', key)
            ele.setAttribute('content', value)
            document.getElementsByTagName('head')[0].appendChild(ele);
        }

        function safeAttrPropertyContentSetter(key, value) {
            for (var i = 0; i < document.getElementsByTagName('head')[0].children.length; i++) {
                var element = document.getElementsByTagName('head')[0].children[i]
                if (element.getAttribute('property') == key) {
                    element.setAttribute('content', value)
                    return
                }
            }
            var ele = document.createElement('meta')
            ele.setAttribute('property', key)
            ele.setAttribute('content', value)
            document.getElementsByTagName('head')[0].appendChild(ele);
        }
    </script>

